{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "lint": "eslint --ext .js index.js lib --max-warnings=0",
    "format": "prettier --write \"**/*.{js,json}\"",
    "format:check": "prettier --check \"**/*.{js,json}\"",
    "postinstall": "node copy-server.js",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "validate:imports": "node validate-imports.js",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": ">=24"
  },
  "main": "index.js",
  "dependencies": {
    "@sentry/node": "^7.72.0",
    "autopromote-server": "file:..",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.1",
    "express-rate-limit": "^6.8.0",
    "fast-xml-parser": "5.8.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.5.0",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.1",
    "googleapis": "^132.0.0",
    "helmet": "^6.0.1",
    "joi": "^18.0.1",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "streamifier": "^0.1.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.1.0"
  },
  "overrides": {
    "axios": "^1.16.1",
    "hono": "4.12.23",
    "@hono/node-server": "^1.19.14",
    "protobufjs": "7.5.8",
    "basic-ftp": "^5.3.1",
    "follow-redirects": "^1.16.0",
    "brace-expansion": "5.0.6",
    "js-yaml": "^4.1.1",
    "glob": "^11.1.0",
    "minimatch": "^10.2.3",
    "node-forge": "1.4.0",
    "@tootallnate/once": "3.0.1",
    "@grpc/grpc-js": "1.14.3",
    "flatted": "3.4.2",
    "fast-uri": "3.1.2",
    "qs": "6.15.2",
    "uuid": "^14.0.0",
    "ws": "8.21.0",
    "lodash": "^4.18.1",
    "router": {
      "path-to-regexp": "8.4.0"
    },
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "jest-util": {
      "picomatch": "4.0.4"
    },
    "minimatch@3": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@5": {
      "brace-expansion": "2.0.3"
    },
    "minimatch@6": {
      "brace-expansion": "2.0.3"
    },
    "minimatch@9": {
      "brace-expansion": "2.0.3"
    },
    "minimatch@10": {
      "brace-expansion": "5.0.6"
    }
  },
  "private": true
}
