    "recharts": "^2.6.2",
    "remotion": "^4.0.423",
    "socket.io-client": "^4.8.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\"",
    "lint": "echo \"Skipping frontend lint due to ESLint v9 migration\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "git add docs && git commit -m \"Update docs for GitHub Pages\" && git push"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^react-router-dom$": "<rootDir>/src/react-router-dom.js",
      "^react-markdown$": "<rootDir>/src/__mocks__/react-markdown.js"
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.4.3",
    "ajv": "^8.18.0",
    "cpy": "^12.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "gh-pages": "^6.3.0",
    "http-proxy-middleware": "^2.0.6",
    "prettier": "^3.8.1"
  }
