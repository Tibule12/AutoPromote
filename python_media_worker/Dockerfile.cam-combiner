ARG MULTICAM_MODEL_CACHE_IMAGE=gcr.io/autopromote-cc6d3/cam-combiner-worker:latest
FROM ${MULTICAM_MODEL_CACHE_IMAGE} AS whisper_model_cache

FROM python:3.10-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PORT=8080 \
    WHISPER_ENGINE=faster \
    FASTER_WHISPER_DEVICE=cpu \
    FASTER_WHISPER_COMPUTE_TYPE=int8 \
    HF_HUB_DISABLE_XET=1 \
    HF_HUB_DOWNLOAD_TIMEOUT=300 \
    ALLOW_RUNTIME_DEPENDENCY_INSTALL=false

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsm6 \
    libxext6 \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.cam-combiner.txt .
RUN pip install --no-cache-dir -r requirements.cam-combiner.txt

# Reuse the already-proven production model instead of depending on a live
# Hugging Face CDN download during every image rebuild.
COPY --from=whisper_model_cache /root/.cache/huggingface /root/.cache/huggingface
RUN HF_HUB_OFFLINE=1 python -c "from faster_whisper import WhisperModel; WhisperModel('small', device='cpu', compute_type='int8', local_files_only=True)"

COPY . .
RUN mkdir -p /app/tmp

EXPOSE 8080
CMD ["sh", "-c", "uvicorn main_media_server:app --host 0.0.0.0 --port ${PORT:-8080}"]
